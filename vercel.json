{
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/recursos/caracoles-resonando",
      "destination": "/recursos/caracoles-resonando/index.html"
    },
    {
      "source": "/recursos/caracoles-resonando/",
      "destination": "/recursos/caracoles-resonando/index.html"
    },
    {
      "source": "/((?!recursos/caracoles-resonando).*)",
      "destination": "/index.html"
    }
  ]
}
